---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Log in">
  <section class="max-w-[400px] mx-auto pt-8">
    <div class="bg-surface border border-outline-soft rounded-2xl shadow-card p-6 sm:p-8">
      <div class="flex flex-col items-center text-center mb-6">
        <span
          class="grid place-items-center size-12 rounded-[12px] bg-primary text-on-primary font-serif font-semibold text-3xl leading-none shadow-[inset_0_-2px_4px_rgba(0,0,0,.12)] mb-4"
          aria-hidden="true"
        >Y</span>
        <h1 class="font-serif text-2xl font-semibold text-on-surface mb-1 tracking-[-0.01em]">Welcome back</h1>
        <p class="font-serif italic text-sm text-on-surface-muted">Sign in to cook together.</p>
      </div>

      <form id="login-form" class="flex flex-col gap-4">
        <label class="flex flex-col gap-1">
          <span class="text-xs font-semibold text-on-surface-muted">Email</span>
          <input
            id="email"
            name="email"
            type="email"
            autocomplete="email"
            required
            class="w-full bg-surface border border-outline-soft rounded-xl px-4 py-3 text-sm text-on-surface focus:outline-none focus:ring-2 focus:ring-primary/40 focus:border-primary transition-colors"
          />
        </label>

        <label class="flex flex-col gap-1">
          <span class="text-xs font-semibold text-on-surface-muted">Password</span>
          <input
            id="password"
            name="password"
            type="password"
            autocomplete="current-password"
            required
            class="w-full bg-surface border border-outline-soft rounded-xl px-4 py-3 text-sm text-on-surface focus:outline-none focus:ring-2 focus:ring-primary/40 focus:border-primary transition-colors"
          />
        </label>

        <p id="login-error" class="hidden text-sm text-primary" role="alert"></p>

        <button
          type="submit"
          id="login-submit"
          class="w-full bg-primary text-on-primary rounded-xl px-4 py-3 text-sm font-semibold shadow-[inset_0_-2px_4px_rgba(0,0,0,.12)] hover:opacity-90 transition-opacity disabled:opacity-50"
        >
          Log in
        </button>
      </form>

      <p class="font-serif italic text-xs text-on-surface-muted text-center mt-6 leading-relaxed">
        Sign-ups are disabled — this kitchen is just for Tim &amp; Zoe.
      </p>
    </div>
  </section>
</Layout>

<script>
  import { supabase } from '../lib/supabase';
  import { signIn } from '../lib/auth';

  const redirect = new URLSearchParams(window.location.search).get('redirect') ?? '/';

  const form = document.getElementById('login-form');
  const errorEl = document.getElementById('login-error');
  const submitBtn = document.getElementById('login-submit');

  if (!form || !errorEl || !submitBtn) throw new Error('Login form elements missing');

  // Already logged in — skip the form
  supabase.auth.getSession().then(({ data: { session } }) => {
    if (session) window.location.href = redirect;
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorEl.classList.add('hidden');
    submitBtn.disabled = true;

    const email = document.getElementById('email').value.trim();
    const password = document.getElementById('password').value;

    const { error } = await signIn(email, password);

    if (error) {
      errorEl.textContent = error.message;
      errorEl.classList.remove('hidden');
      submitBtn.disabled = false;
      return;
    }

    window.location.href = redirect;
  });
</script>
