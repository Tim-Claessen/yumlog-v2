---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Shopping list" activeNav="shopping">
  <div id="auth-checking" class="text-on-surface-muted text-center py-20 text-sm">
    Checking session…
  </div>

  <div id="auth-content" class="hidden">
    <header class="flex items-baseline justify-between gap-4 mb-6">
      <div>
        <h1 class="font-serif text-2xl font-bold text-on-surface">Shopping list</h1>
        <p class="text-sm text-on-surface-muted mt-1">Shared between Tim &amp; Zoe</p>
      </div>
      <div class="flex flex-col items-end gap-1 shrink-0">
        <button
          type="button"
          id="clear-checked"
          class="hidden text-sm font-medium text-primary hover:underline"
        >
          Clear checked
        </button>
        <button
          type="button"
          id="clear-all"
          class="hidden text-sm font-medium text-on-surface-muted hover:text-primary transition-colors"
        >
          Clear list
        </button>
      </div>
    </header>

    <!-- Clear-all confirmation -->
    <div
      id="clear-all-dialog"
      class="hidden fixed inset-0 z-50 flex items-end sm:items-center justify-center p-4"
      role="dialog"
      aria-modal="true"
      aria-labelledby="clear-all-title"
    >
      <div class="absolute inset-0 bg-on-surface/25 backdrop-blur-[2px]" data-dialog-backdrop></div>
      <div class="relative w-full max-w-sm bg-surface rounded-2xl border border-outline-soft shadow-xl overflow-hidden">
        <div class="bg-primary-container/40 px-5 pt-5 pb-4">
          <p class="text-xs font-medium text-on-surface-muted uppercase tracking-widest mb-1">Just checking</p>
          <h2 id="clear-all-title" class="font-serif text-xl font-bold text-on-surface leading-snug">
            Clear the whole list?
          </h2>
        </div>
        <div class="px-5 py-4">
          <p class="text-sm text-on-surface-muted leading-relaxed">
            This removes <strong class="font-medium text-on-surface">every item</strong> for both Tim and Zoe — not just the ticked ones. There&rsquo;s no undo.
          </p>
          <div class="flex gap-3 mt-5">
            <button
              type="button"
              id="clear-all-cancel"
              class="flex-1 rounded-xl px-4 py-2.5 text-sm font-medium text-on-surface-muted bg-surface-container hover:bg-surface-container/80 transition-colors"
            >
              Keep list
            </button>
            <button
              type="button"
              id="clear-all-confirm"
              class="flex-1 rounded-xl px-4 py-2.5 text-sm font-medium text-on-primary bg-primary hover:opacity-90 transition-opacity"
            >
              Yes, clear all
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Manual add -->
    <form
      id="add-item-form"
      class="bg-surface-low/80 rounded-2xl p-4 mb-6 flex flex-wrap gap-2 items-end"
    >
      <label class="flex flex-col gap-1 flex-1 min-w-[10rem]">
        <span class="text-xs font-medium text-on-surface-muted">Ingredient</span>
        <div class="relative">
          <input
            id="add-name"
            type="text"
            required
            placeholder="e.g. mushrooms"
            autocomplete="off"
            class="w-full bg-surface-container/50 border border-transparent rounded-xl px-3 py-2 text-sm text-on-surface placeholder:text-outline/70 focus:bg-surface-container focus:border-outline-soft/60 focus:outline-none transition-colors"
          />
          <ul
            id="add-name-suggestions"
            class="autocomplete-list hidden absolute z-10 left-0 right-0 top-full mt-1 bg-white border border-outline-soft rounded-xl shadow-lg overflow-hidden max-h-48 overflow-y-auto"
          ></ul>
        </div>
      </label>
      <label class="flex flex-col gap-1 w-[4.25rem] shrink-0">
        <span class="text-xs font-medium text-on-surface-muted">Qty</span>
        <input
          id="add-qty"
          type="text"
          inputmode="decimal"
          placeholder="—"
          class="w-full bg-surface-container/50 border border-transparent rounded-lg px-2 py-2 text-xs text-on-surface-muted text-right tabular-nums placeholder:text-outline/70 focus:text-on-surface focus:bg-surface-container focus:border-outline-soft/60 focus:outline-none transition-colors"
        />
      </label>
      <label class="flex flex-col gap-1 w-[4.25rem] shrink-0">
        <span class="text-xs font-medium text-on-surface-muted">Unit</span>
        <select
          id="add-unit"
          class="w-full bg-surface-container/50 border border-transparent rounded-lg px-1.5 py-2 text-xs text-on-surface-muted focus:text-on-surface focus:bg-surface-container focus:border-outline-soft/60 focus:outline-none transition-colors"
        >
          <option value="each">each</option>
          <option value="g">g</option>
          <option value="kg">kg</option>
          <option value="ml">ml</option>
          <option value="cup">cup</option>
          <option value="tsp">tsp</option>
          <option value="tbsp">tbsp</option>
          <option value="pinch">pinch</option>
          <option value="dash">dash</option>
          <option value="sprig">sprig</option>
          <option value="handful">handful</option>
        </select>
      </label>
      <button
        type="submit"
        class="bg-primary text-on-primary rounded-2xl px-4 py-2.5 text-sm font-medium hover:opacity-90 transition-opacity sm:mb-0"
      >
        Add
      </button>
    </form>

    <p id="shopping-error" class="hidden text-sm text-primary mb-4" role="alert"></p>

    <p id="shopping-empty" class="hidden text-on-surface-muted text-center py-16 text-sm">
      Nothing on the list yet — add from a recipe or type an item above.
    </p>

    <div
      id="list-view-controls"
      class="hidden flex items-center justify-end gap-2.5 mb-3"
    >
      <span class="text-xs font-medium text-on-surface-muted">By aisle</span>
      <button
        type="button"
        id="group-by-aisle"
        role="switch"
        aria-checked="true"
        aria-label="Group shopping list by aisle"
        class="inline-flex h-6 w-11 shrink-0 cursor-pointer items-center rounded-full bg-primary p-0.5 transition-colors duration-200 ease-out focus:outline-none focus-visible:ring-2 focus-visible:ring-primary/40"
      >
        <span
          class="switch-thumb pointer-events-none block size-5 shrink-0 rounded-full bg-white shadow-sm transition-transform duration-200 ease-out translate-x-5"
          aria-hidden="true"
        ></span>
      </button>
    </div>

    <div id="shopping-list" class="flex flex-col"></div>
  </div>
</Layout>

<script>
  import { requireAuth } from '../lib/auth';
  import { initShoppingListUI } from '../lib/shopping-list-ui';

  const checking = document.getElementById('auth-checking');
  const content = document.getElementById('auth-content');

  requireAuth().then(async ok => {
    if (!ok || !checking || !content) return;
    checking.classList.add('hidden');
    content.classList.remove('hidden');
    await initShoppingListUI();
  });
</script>
