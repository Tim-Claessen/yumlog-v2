---
import Layout from '../../layouts/Layout.astro';
import { supabase } from '../../lib/supabase';
import { toDisplayLabel, splitValues, parseStepLabel, stripBullet } from '../../lib/format';
import { displayIngredientName } from '../../lib/ingredient';

export async function getStaticPaths() {
  const { data: recipes } = await supabase.from('recipes').select('slug');
  return (recipes ?? []).map(r => ({ params: { slug: r.slug } }));
}

const { slug } = Astro.params;

const [{ data: recipe }, { data: ingredients }] = await Promise.all([
  supabase.from('recipes').select('*').eq('slug', slug!).single(),
  supabase
    .from('recipe_ingredients')
    .select('display_name, ingredient, quantity, unit')
    .eq('recipe_slug', slug!)
    .order('id'),
]);

if (!recipe) return Astro.redirect('/');

// Parse the multi-line method into individual steps (skip blank lines)
const methodSteps: string[] = (recipe.method ?? '')
  .split('\n')
  .map((l: string) => l.trim())
  .filter(Boolean);

// Parse tips — stored one per line, may have leading bullet
const tipLines: string[] = (recipe.tips ?? '')
  .split('\n')
  .map((l: string) => stripBullet(l.trim()))
  .filter(Boolean);

// Parse substitutions — stored one per line, may have leading bullet
const subLines: string[] = (recipe.substitutions ?? '')
  .split('\n')
  .map((l: string) => stripBullet(l.trim()))
  .filter(Boolean);

// Format ingredient amount; omit the word "each" per display rules
function formatAmount(quantity: number | string | null, unit: string | null): string {
  const qty = quantity != null ? String(+quantity) : '';
  const u   = unit === 'each' ? '' : (unit ?? '');
  return [qty, u].filter(Boolean).join(' ');
}

const categoryChips = splitValues(recipe.category);
const proteinChips  = splitValues(recipe.protein);

const shoppingIngredients = (ingredients ?? []).map(ing => ({
  ingredient: ing.ingredient,
  quantity: ing.quantity,
  unit: ing.unit,
}));
---

<Layout title={recipe.title} activeNav="recipes">

  <script id="recipe-shopping-data" type="application/json" set:html={JSON.stringify(shoppingIngredients)}></script>

  <!-- Back link -->
  <a href="/" class="inline-flex items-center gap-1.5 text-sm text-on-surface-muted hover:text-primary mb-5 transition-colors">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <polyline points="15 18 9 12 15 6"/>
    </svg>
    All recipes
  </a>

  <!-- Edit controls (authenticated only) -->
  <div data-auth-only class="hidden flex flex-wrap gap-2 mb-5">
    <a
      href={`/create?edit=${slug}`}
      class="inline-flex items-center gap-1.5 text-sm font-medium text-primary border border-primary/30 rounded-full px-3 py-1.5 hover:bg-primary-container transition-colors"
    >
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
      </svg>
      Edit recipe
    </a>
    <button
      type="button"
      id="add-to-shopping"
      data-slug={slug}
      class="inline-flex items-center gap-1.5 text-sm font-medium text-secondary border border-secondary/30 rounded-full px-3 py-1.5 hover:bg-secondary-container transition-colors"
    >
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
      </svg>
      Add to shopping list
    </button>
  </div>

  <!-- Header -->
  <header class="mb-8">
    <h1 class="font-serif text-2xl font-bold text-on-surface mb-3 leading-snug">
      {recipe.title}
    </h1>

    <div class="flex flex-wrap items-center gap-2">
      {categoryChips.map(c => (
        <span class="bg-primary-container text-on-primary-container text-xs rounded-full px-2 py-0.5 font-medium">
          {toDisplayLabel(c)}
        </span>
      ))}
      {proteinChips.map(p => (
        <span class="text-xs text-on-surface-muted">{toDisplayLabel(p)}</span>
      ))}
      {recipe.cook_time_min && (
        <span class="text-xs text-on-surface-muted whitespace-nowrap">{recipe.cook_time_min}&thinsp;min</span>
      )}
      {recipe.source_url && (
        <a
          href={recipe.source_url}
          target="_blank"
          rel="noopener noreferrer"
          class="text-xs text-primary hover:underline"
        >
          Source &rarr;
        </a>
      )}
    </div>
  </header>

  <!-- Ingredients -->
  {ingredients && ingredients.length > 0 && (
    <section class="mb-8">
      <h2 class="font-serif text-xl font-bold text-on-surface mb-3">Ingredients</h2>
      <ul class="flex flex-col gap-1.5">
        {ingredients.map(ing => {
          const amount = formatAmount(ing.quantity, ing.unit);
          const name = displayIngredientName(
            ing.display_name ?? ing.ingredient,
            ing.quantity,
            ing.unit,
          );
          return (
            <li class="flex items-baseline gap-4">
              <span class="text-primary/70 tabular-nums text-sm shrink-0 w-16 text-right">
                {amount}
              </span>
              <span class="text-on-surface text-sm">
                {name}
              </span>
            </li>
          );
        })}
      </ul>
    </section>
  )}

  <!-- Method -->
  {methodSteps.length > 0 && (
    <section class="mb-8">
      <h2 class="font-serif text-xl font-bold text-on-surface mb-4">Method</h2>
      <ol class="flex flex-col gap-3 list-none pl-0">
        {methodSteps.map((step, i) => {
          const { label, body } = parseStepLabel(step);
          return (
            <li class="flex gap-3">
              <span class="shrink-0 w-5 text-sm font-medium text-on-surface-muted tabular-nums pt-0.5">
                {i + 1}.
              </span>
              <p class="text-on-surface text-sm leading-relaxed">
                {label && <strong class="font-semibold">{label}: </strong>}
                {body}
              </p>
            </li>
          );
        })}
      </ol>
    </section>
  )}

  <!-- Tips -->
  {tipLines.length > 0 && (
    <section class="mb-8">
      <h2 class="font-serif text-xl font-bold text-on-surface mb-3">Tips</h2>
      <ul class="flex flex-col gap-2 list-disc pl-5 marker:text-on-surface-muted">
        {tipLines.map(tip => {
          const { label, body } = parseStepLabel(tip);
          return (
            <li class="text-sm text-on-surface leading-relaxed pl-1">
              {label && <strong class="font-semibold">{label}: </strong>}
              {body}
            </li>
          );
        })}
      </ul>
    </section>
  )}

  <!-- Substitutions -->
  {subLines.length > 0 && (
    <section class="mb-8">
      <h2 class="font-serif text-xl font-bold text-on-surface mb-3">Substitutions</h2>
      <ul class="flex flex-col gap-2 list-disc pl-5 marker:text-on-surface-muted">
        {subLines.map(sub => {
          const { label, body } = parseStepLabel(sub);
          return (
            <li class="text-sm text-on-surface leading-relaxed pl-1">
              {label && <strong class="font-semibold">{label}: </strong>}
              {body}
            </li>
          );
        })}
      </ul>
    </section>
  )}

</Layout>

<script>
  import { getSession } from '../../lib/auth';
  import { addRecipeIngredientsToList } from '../../lib/shopping-list';

  const btn = document.getElementById('add-to-shopping');
  const dataEl = document.getElementById('recipe-shopping-data');

  btn?.addEventListener('click', async () => {
    const session = await getSession();
    if (!session) {
      const redirect = encodeURIComponent(window.location.pathname);
      window.location.href = `/login?redirect=${redirect}`;
      return;
    }

    if (!dataEl?.textContent) return;

    const originalHtml = btn.innerHTML;
    btn.disabled = true;
    btn.textContent = 'Adding…';

    try {
      const ingredients = JSON.parse(dataEl.textContent);
      await addRecipeIngredientsToList(ingredients);
      btn.textContent = 'Added!';
      setTimeout(() => { window.location.href = '/shopping'; }, 600);
    } catch (err) {
      btn.disabled = false;
      btn.innerHTML = originalHtml;
      alert(err instanceof Error ? err.message : 'Could not add to shopping list');
    }
  });
</script>
