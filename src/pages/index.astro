---
import Layout from '../layouts/Layout.astro';
import { supabase } from '../lib/supabase';
import { toDisplayLabel, splitValues } from '../lib/format';

const FEATURED_SLUGS = ['sourdough-bread', 'mixed-berry-muffins', 'mexican-rice-arroz-rojo'] as const;

const [{ data: recipes }, { data: featuredRaw }] = await Promise.all([
  supabase
    .from('recipes')
    .select('slug, title, category, protein, cook_time_min')
    .order('title'),
  supabase
    .from('recipes')
    .select('slug, title, category, protein, cook_time_min')
    .in('slug', [...FEATURED_SLUGS]),
]);

const list = recipes ?? [];
const featuredBySlug = new Map((featuredRaw ?? []).map(r => [r.slug, r]));
const featured = FEATURED_SLUGS
  .map(slug => featuredBySlug.get(slug))
  .filter((r): r is NonNullable<typeof r> => r != null);

// Build unique chip values by splitting multi-value fields
const categoryValues = [...new Set(
  list.flatMap(r => splitValues(r.category))
)].sort();

const proteinValues = [...new Set(
  list.flatMap(r => splitValues(r.protein))
)].sort();
---

<Layout title="Yumlog" activeNav="recipes">

  <!-- Hero + search -->
  <section class="bg-surface-low/80 rounded-2xl px-5 py-6 mb-6">
    <div class="flex items-center justify-between gap-4 mb-5">
      <div>
        <p class="text-xs font-medium text-on-surface-muted uppercase tracking-widest mb-1">Tim &amp; Zoe's kitchen</p>
        <h1 class="font-serif text-2xl font-bold text-on-surface leading-snug">
          Everything we cook,<br />all in one place.
        </h1>
      </div>
      <svg class="shrink-0 text-primary opacity-50" width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M3 11l19-9-9 19-2-8-8-2z"/>
      </svg>
    </div>
    <div class="relative">
      <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 text-outline/70" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
      </svg>
      <input
        id="search"
        type="search"
        placeholder="Search recipes…"
        autocomplete="off"
        class="w-full bg-surface-container/50 border border-transparent rounded-xl pl-10 pr-4 py-2.5 text-sm text-on-surface placeholder:text-outline/70 focus:bg-surface-container focus:border-outline-soft/60 focus:outline-none transition-colors"
      />
    </div>
  </section>

  <!-- Featured -->
  {featured.length > 0 && (
    <section class="mb-6">
      <h2 class="font-serif text-lg font-bold text-on-surface mb-3">Featured</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
        {featured.map(r => (
          <a
            href={`/recipes/${r.slug}`}
            class="group block bg-primary-container rounded-2xl px-4 py-4 hover:brightness-[0.98] active:brightness-95 transition-all"
          >
            <h3 class="font-serif font-bold text-on-primary-container leading-snug group-hover:text-primary transition-colors">
              {r.title}
            </h3>
            <p class="text-xs text-on-surface-muted mt-1.5">
              {splitValues(r.category).slice(0, 1).map(c => toDisplayLabel(c))}
              {r.cook_time_min && (
                <span class="before:content-['·'] before:mx-1.5">{r.cook_time_min}&thinsp;min</span>
              )}
            </p>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- Filters -->
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 mb-5">
    <label class="flex flex-col gap-1">
      <span class="text-xs font-medium text-on-surface-muted">Category</span>
      <select
        id="filter-category"
        class="filter-select w-full bg-surface-container/50 border border-transparent rounded-xl px-3 py-2 text-sm text-on-surface-muted focus:text-on-surface focus:bg-surface-container focus:border-outline-soft/60 focus:outline-none transition-colors"
      >
        <option value="">All categories</option>
        {categoryValues.map(v => (
          <option value={v}>{toDisplayLabel(v)}</option>
        ))}
      </select>
    </label>

    <label class="flex flex-col gap-1">
      <span class="text-xs font-medium text-on-surface-muted">Protein</span>
      <select
        id="filter-protein"
        class="filter-select w-full bg-surface-container/50 border border-transparent rounded-xl px-3 py-2 text-sm text-on-surface-muted focus:text-on-surface focus:bg-surface-container focus:border-outline-soft/60 focus:outline-none transition-colors"
      >
        <option value="">All proteins</option>
        {proteinValues.map(v => (
          <option value={v}>{toDisplayLabel(v)}</option>
        ))}
      </select>
    </label>

    <label class="flex flex-col gap-1">
      <span class="text-xs font-medium text-on-surface-muted">Cook time</span>
      <select
        id="filter-time"
        class="filter-select w-full bg-surface-container/50 border border-transparent rounded-xl px-3 py-2 text-sm text-on-surface-muted focus:text-on-surface focus:bg-surface-container focus:border-outline-soft/60 focus:outline-none transition-colors"
      >
        <option value="">Any time</option>
        <option value="under30">&lt; 30 min</option>
        <option value="30to60">30–60 min</option>
        <option value="over60">&gt; 60 min</option>
      </select>
    </label>
  </div>

  <!-- All recipes -->
  <section>
    <div class="flex items-baseline justify-between mb-3">
      <h2 class="font-serif text-lg font-bold text-on-surface">
        All recipes <span id="recipe-count" class="text-base font-sans font-normal text-on-surface-muted">({list.length})</span>
      </h2>
      <button id="clear-filters" class="hidden text-xs font-medium text-primary hover:underline">
        Clear filters
      </button>
    </div>

    {list.length === 0 && (
      <p class="text-on-surface-muted text-center py-20">No recipes yet — check back soon.</p>
    )}

    <ul id="recipe-list" class="flex flex-col divide-y divide-outline-soft">
      {list.map(r => (
        <li
          data-title={r.title.toLowerCase()}
          data-category={r.category ?? ''}
          data-protein={r.protein ?? ''}
          data-cook-time={r.cook_time_min ?? ''}
        >
          <a
            href={`/recipes/${r.slug}`}
            class="flex items-center justify-between gap-3 py-3.5 hover:bg-surface-low active:bg-surface-container transition-colors -mx-1 px-1 rounded-lg"
          >
            <span class="font-medium text-on-surface">{r.title}</span>
            <span class="flex items-center gap-2 shrink-0">
              {splitValues(r.category).slice(0, 1).map(c => (
                <span class="bg-primary-container text-on-primary-container text-xs rounded-full px-2 py-0.5 font-medium">
                  {toDisplayLabel(c)}
                </span>
              ))}
              {r.cook_time_min && (
                <span class="text-xs text-on-surface-muted whitespace-nowrap">{r.cook_time_min}&thinsp;min</span>
              )}
            </span>
          </a>
        </li>
      ))}
    </ul>

    <p id="no-results" class="hidden text-on-surface-muted text-center py-20">
      No recipes match these filters.
    </p>
  </section>

</Layout>

<script>
  // ── State ────────────────────────────────────────────────────────────────────
  const activeFilters: Record<string, string> = {
    category: '',
    protein:  '',
    time:     '',
  };

  // ── Elements ─────────────────────────────────────────────────────────────────
  const searchEl   = document.getElementById('search')        as HTMLInputElement;
  const listEl     = document.getElementById('recipe-list')!;
  const countEl    = document.getElementById('recipe-count')!;
  const noRes      = document.getElementById('no-results')!;
  const clearBtn   = document.getElementById('clear-filters')!;
  const rows       = listEl ? Array.from(listEl.querySelectorAll<HTMLLIElement>('li')) : [];

  // ── Helpers ──────────────────────────────────────────────────────────────────
  function matchesMulti(stored: string, filterValue: string): boolean {
    if (!filterValue) return true;
    return stored.split(',').map(v => v.trim()).includes(filterValue);
  }

  function applyFilters() {
    const query = searchEl?.value.toLowerCase().trim() ?? '';
    const { category, protein, time } = activeFilters;
    const hasActive = query || category || protein || time;
    let visible = 0;

    rows.forEach(row => {
      const titleMatch = !query || (row.dataset.title ?? '').includes(query);
      const catMatch   = matchesMulti(row.dataset.category ?? '', category);
      const protMatch  = matchesMulti(row.dataset.protein  ?? '', protein);
      const mins       = parseInt(row.dataset.cookTime ?? '0', 10);
      let timeMatch    = true;
      if      (time === 'under30') timeMatch = mins > 0 && mins <= 30;
      else if (time === '30to60')  timeMatch = mins > 30 && mins <= 60;
      else if (time === 'over60')  timeMatch = mins > 60;

      const show = titleMatch && catMatch && protMatch && timeMatch;
      row.hidden = !show;
      if (show) visible++;
    });

    countEl.textContent = `(${visible})`;
    noRes.classList.toggle('hidden', visible > 0 || rows.length === 0);
    clearBtn.classList.toggle('hidden', !hasActive);
  }

  // ── Dropdown changes ─────────────────────────────────────────────────────────
  const categoryEl = document.getElementById('filter-category') as HTMLSelectElement;
  const proteinEl  = document.getElementById('filter-protein')  as HTMLSelectElement;
  const timeEl     = document.getElementById('filter-time')     as HTMLSelectElement;

  function syncFiltersFromSelects() {
    activeFilters.category = categoryEl?.value ?? '';
    activeFilters.protein  = proteinEl?.value  ?? '';
    activeFilters.time     = timeEl?.value     ?? '';
    applyFilters();
  }

  categoryEl?.addEventListener('change', syncFiltersFromSelects);
  proteinEl?.addEventListener('change', syncFiltersFromSelects);
  timeEl?.addEventListener('change', syncFiltersFromSelects);

  // ── Search ───────────────────────────────────────────────────────────────────
  searchEl?.addEventListener('input', applyFilters);

  // ── Clear all ────────────────────────────────────────────────────────────────
  clearBtn?.addEventListener('click', () => {
    if (searchEl) searchEl.value = '';
    if (categoryEl) categoryEl.value = '';
    if (proteinEl)  proteinEl.value  = '';
    if (timeEl)     timeEl.value     = '';
    Object.keys(activeFilters).forEach(k => { activeFilters[k] = ''; });
    applyFilters();
  });
</script>

