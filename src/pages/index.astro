---
import Layout from '../layouts/Layout.astro';
import { supabase } from '../lib/supabase';
import { toDisplayLabel, splitValues } from '../lib/format';

const FEATURED_SLUGS = ['sourdough-bread', 'mixed-berry-muffins', 'mexican-rice-arroz-rojo'] as const;

const [{ data: recipes }, { data: featuredRaw }] = await Promise.all([
  supabase
    .from('recipes')
    .select('slug, title, category, protein, cook_time_min')
    .order('title'),
  supabase
    .from('recipes')
    .select('slug, title, category, protein, cook_time_min')
    .in('slug', [...FEATURED_SLUGS]),
]);

const list = recipes ?? [];
const featuredBySlug = new Map((featuredRaw ?? []).map(r => [r.slug, r]));
const featured = FEATURED_SLUGS
  .map(slug => featuredBySlug.get(slug))
  .filter((r): r is NonNullable<typeof r> => r != null);

// Build unique chip values by splitting multi-value fields
const categoryValues = [...new Set(
  list.flatMap(r => splitValues(r.category))
)].sort();

const proteinValues = [...new Set(
  list.flatMap(r => splitValues(r.protein))
)].sort();
---

<Layout title="Yumlog" activeNav="recipes">

  <!-- Hero + search + filter (sticky) -->
  <section id="hero" class="bg-surface border border-outline-soft rounded-2xl shadow-card px-5 py-6 mb-6 sm:mb-6 sticky top-16 z-10 transition-[padding,box-shadow,margin] duration-300">
    <div id="hero-intro" class="flex items-start justify-between gap-4 mb-5 overflow-hidden will-change-[opacity,transform,max-height]">
      <div>
        <p class="text-[11px] font-bold text-primary uppercase tracking-[0.15em] mb-1.5">Tim &amp; Zoe's kitchen</p>
        <h1 class="font-serif text-[34px] font-semibold text-on-surface leading-[1.1] tracking-[-0.01em]">
          Everything we cook,<br /><em class="text-primary">all in one place.</em>
        </h1>
      </div>
      <p class="shrink-0 font-serif italic text-sm text-on-surface-muted pt-1 tabular-nums">{list.length} recipes</p>
    </div>
    <div class="flex items-center gap-2">
      <div class="relative flex-1 min-w-0">
        <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 text-outline" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
        <input
          id="search"
          type="search"
          placeholder="Search recipes…"
          autocomplete="off"
          class="w-full bg-surface border border-outline-soft rounded-[13px] pl-10 pr-4 py-2.5 text-sm text-on-surface placeholder:text-outline/70 focus:border-outline focus:outline-none transition-colors"
        />
      </div>
      <button
        type="button"
        id="filter-toggle"
        class="relative shrink-0 inline-flex items-center justify-center size-11 bg-surface border border-outline-soft rounded-[13px] text-on-surface-muted hover:text-on-surface hover:border-outline focus:border-outline focus:outline-none transition-colors"
        aria-expanded="false"
        aria-controls="filter-panel"
        aria-label="Filters"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="4" y1="6" x2="20" y2="6"/><line x1="8" y1="12" x2="16" y2="12"/><line x1="10" y1="18" x2="14" y2="18"/>
        </svg>
        <span id="filter-badge" class="hidden absolute -top-1 -right-1 min-w-[1.125rem] h-[1.125rem] px-1 rounded-full bg-primary text-on-primary text-[10px] font-medium items-center justify-center leading-none"></span>
      </button>
    </div>
    <div id="active-filter-chips" class="hidden flex flex-wrap gap-2 mt-2"></div>
  </section>

  <!-- Featured (hidden while searching, filtering, or scrolled on mobile) -->
  {featured.length > 0 && (
    <section id="featured-section" class="mb-5 sm:mb-6 transition-all duration-300">
      <h2 class="font-serif text-sm sm:text-lg font-bold text-on-surface mb-2 sm:mb-3">Featured</h2>
      <div class="grid grid-cols-3 gap-2 sm:gap-3">
        {featured.map((r, i) => {
          const isSecondary = i === 1;
          const cardBg = isSecondary ? 'bg-secondary-container' : 'bg-primary-container';
          const titleColor = isSecondary ? 'text-on-secondary-container' : 'text-on-primary-container';
          const eyebrowColor = isSecondary ? 'text-secondary' : 'text-primary';
          const category = splitValues(r.category).slice(0, 1)[0];
          return (
          <a
            href={`/recipes/${r.slug}`}
            class={`group min-w-0 flex flex-col justify-end min-h-[5.5rem] sm:min-h-[6.5rem] ${cardBg} rounded-2xl p-4 sm:p-5 hover:brightness-[0.98] active:brightness-95 transition-all`}
          >
            {category && (
              <p class={`text-[11px] font-bold uppercase tracking-[0.15em] ${eyebrowColor} mb-1.5`}>
                {toDisplayLabel(category)}
              </p>
            )}
            <h3 class={`font-serif text-[11px] sm:text-sm font-semibold ${titleColor} leading-tight line-clamp-3`}>
              {r.title}
            </h3>
          </a>
          );
        })}
      </div>
    </section>
  )}

  <!-- Filter panel -->
  <div
    id="filter-panel"
    class="hidden fixed inset-0 z-30"
    role="dialog"
    aria-modal="true"
    aria-labelledby="filter-panel-title"
  >
    <div class="absolute inset-0 bg-on-surface/20" id="filter-panel-backdrop"></div>
    <div class="absolute inset-x-0 bottom-0 sm:bottom-auto sm:top-1/2 sm:-translate-y-1/2 sm:max-w-md sm:mx-auto bg-surface rounded-t-2xl sm:rounded-2xl border-t sm:border border-outline-soft shadow-xl max-h-[85vh] overflow-y-auto">
      <div class="flex items-center justify-between px-4 py-3 border-b border-outline-soft/60">
        <h2 id="filter-panel-title" class="font-serif text-lg font-bold text-on-surface">Filters</h2>
        <div class="flex items-center gap-1">
          <button type="button" id="filter-panel-clear" class="hidden text-sm font-medium text-primary px-2 py-1">Clear filters</button>
          <button type="button" id="filter-panel-close" class="text-sm font-medium text-primary px-2 py-1">Done</button>
        </div>
      </div>
      <div class="p-4 flex flex-col gap-4">
        <label class="flex flex-col gap-1">
          <span class="text-xs font-medium text-on-surface-muted">Category</span>
          <select
            id="filter-category"
            class="filter-select w-full bg-surface-container/50 border border-transparent rounded-xl px-3 py-2 text-sm text-on-surface-muted focus:text-on-surface focus:bg-surface-container focus:border-outline-soft/60 focus:outline-none transition-colors"
          >
            <option value="">All categories</option>
            {categoryValues.map(v => (
              <option value={v}>{toDisplayLabel(v)}</option>
            ))}
          </select>
        </label>
        <label class="flex flex-col gap-1">
          <span class="text-xs font-medium text-on-surface-muted">Protein</span>
          <select
            id="filter-protein"
            class="filter-select w-full bg-surface-container/50 border border-transparent rounded-xl px-3 py-2 text-sm text-on-surface-muted focus:text-on-surface focus:bg-surface-container focus:border-outline-soft/60 focus:outline-none transition-colors"
          >
            <option value="">All proteins</option>
            {proteinValues.map(v => (
              <option value={v}>{toDisplayLabel(v)}</option>
            ))}
          </select>
        </label>
        <label class="flex flex-col gap-1">
          <span class="text-xs font-medium text-on-surface-muted">Cook time</span>
          <select
            id="filter-time"
            class="filter-select w-full bg-surface-container/50 border border-transparent rounded-xl px-3 py-2 text-sm text-on-surface-muted focus:text-on-surface focus:bg-surface-container focus:border-outline-soft/60 focus:outline-none transition-colors"
          >
            <option value="">Any time</option>
            <option value="under30">&lt; 30 min</option>
            <option value="30to60">30–60 min</option>
            <option value="over60">&gt; 60 min</option>
          </select>
        </label>
      </div>
    </div>
  </div>

  <!-- All recipes -->
  <section>
    <div class="flex items-baseline justify-between mb-3">
      <h2 class="font-serif text-lg font-bold text-on-surface">
        All recipes <span id="recipe-count" class="text-base font-sans font-normal text-on-surface-muted tabular-nums">({list.length})</span>
      </h2>
      <button id="clear-filters" class="hidden text-xs font-medium text-primary hover:underline">
        Clear filters
      </button>
    </div>

    {list.length === 0 && (
      <p class="text-on-surface-muted text-center py-20">No recipes yet — check back soon.</p>
    )}

    <ul id="recipe-list" class="flex flex-col divide-y divide-outline-soft bg-surface border border-outline-soft rounded-2xl overflow-hidden">
      {list.map(r => (
        <li
          data-title={r.title.toLowerCase()}
          data-category={r.category ?? ''}
          data-protein={r.protein ?? ''}
          data-cook-time={r.cook_time_min ?? ''}
        >
          <a
            href={`/recipes/${r.slug}`}
            class="flex items-center justify-between gap-3 py-3.5 px-4 hover:bg-surface-low active:bg-surface-container transition-colors"
          >
            <span class="font-medium text-on-surface">{r.title}</span>
            <span class="flex items-center gap-2 shrink-0">
              {splitValues(r.category).slice(0, 1).map(c => (
                <span class="bg-primary-container text-on-primary-container text-[11px] rounded-full px-2 py-0.5 font-medium">
                  {toDisplayLabel(c)}
                </span>
              ))}
              {r.cook_time_min && (
                <span class="text-xs text-on-surface-muted whitespace-nowrap tabular-nums">{r.cook_time_min}&thinsp;min</span>
              )}
            </span>
          </a>
        </li>
      ))}
    </ul>

    <p id="no-results" class="hidden text-on-surface-muted text-center py-20">
      No recipes match these filters.
    </p>
  </section>

</Layout>

<script>
  // ── State ────────────────────────────────────────────────────────────────────
  const activeFilters: Record<string, string> = {
    category: '',
    protein:  '',
    time:     '',
  };

  const TIME_LABELS: Record<string, string> = {
    under30: '< 30 min',
    '30to60': '30–60 min',
    over60: '> 60 min',
  };

  // ── Elements ─────────────────────────────────────────────────────────────────
  const searchEl   = document.getElementById('search')        as HTMLInputElement;
  const listEl     = document.getElementById('recipe-list')!;
  const countEl    = document.getElementById('recipe-count')!;
  const noRes      = document.getElementById('no-results')!;
  const clearBtn   = document.getElementById('clear-filters')!;
  const featuredEl = document.getElementById('featured-section');
  const heroEl     = document.getElementById('hero');
  const heroIntro  = document.getElementById('hero-intro');
  const filterBadge = document.getElementById('filter-badge');
  const filterChips = document.getElementById('active-filter-chips');
  const filterPanel = document.getElementById('filter-panel');
  const filterToggle = document.getElementById('filter-toggle');
  const filterPanelClear = document.getElementById('filter-panel-clear');
  const rows       = listEl ? Array.from(listEl.querySelectorAll<HTMLLIElement>('li')) : [];

  const categoryEl = document.getElementById('filter-category') as HTMLSelectElement;
  const proteinEl  = document.getElementById('filter-protein')  as HTMLSelectElement;
  const timeEl     = document.getElementById('filter-time')     as HTMLSelectElement;

  // ── Helpers ──────────────────────────────────────────────────────────────────
  function matchesMulti(stored: string, filterValue: string): boolean {
    if (!filterValue) return true;
    return stored.split(',').map(v => v.trim()).includes(filterValue);
  }

  function optionLabel(select: HTMLSelectElement | null, value: string): string {
    if (!select || !value) return '';
    const opt = select.querySelector(`option[value="${CSS.escape(value)}"]`);
    return opt?.textContent?.trim() ?? value;
  }

  function syncFiltersFromSelects() {
    activeFilters.category = categoryEl?.value ?? '';
    activeFilters.protein  = proteinEl?.value  ?? '';
    activeFilters.time     = timeEl?.value     ?? '';
    applyFilters();
  }

  function updateActiveChips() {
    const chips: { key: string; label: string }[] = [];
    const { category, protein, time } = activeFilters;

    if (category) chips.push({ key: 'category', label: optionLabel(categoryEl, category) });
    if (protein)  chips.push({ key: 'protein',  label: optionLabel(proteinEl, protein) });
    if (time)     chips.push({ key: 'time',     label: TIME_LABELS[time] ?? time });

    const count = chips.length;
    if (filterBadge) {
      filterBadge.textContent = count > 0 ? String(count) : '';
      filterBadge.classList.toggle('hidden', count === 0);
      filterBadge.classList.toggle('flex', count > 0);
    }

    const hasFilterSelects = Boolean(category || protein || time);
    filterPanelClear?.classList.toggle('hidden', !hasFilterSelects);

    if (!filterChips) return;
    filterChips.innerHTML = '';
    if (chips.length === 0) {
      filterChips.classList.add('hidden');
      return;
    }

    filterChips.classList.remove('hidden');
    for (const chip of chips) {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'inline-flex items-center gap-1 bg-primary-container text-on-primary-container text-xs rounded-full px-2.5 py-1 font-medium';
      btn.innerHTML = `${chip.label}<span aria-hidden="true">×</span>`;
      btn.setAttribute('aria-label', `Remove ${chip.label} filter`);
      btn.addEventListener('click', () => {
        activeFilters[chip.key] = '';
        if (chip.key === 'category' && categoryEl) categoryEl.value = '';
        else if (chip.key === 'protein' && proteinEl) proteinEl.value = '';
        else if (chip.key === 'time' && timeEl) timeEl.value = '';
        applyFilters();
      });
      filterChips.appendChild(btn);
    }
  }

  const HERO_DISMISS_PX = 40;
  let heroCollapsed = false;
  let heroIntroFullHeight = 0;

  /** Steep curve — welcome copy is mostly gone in the first ~25px of scroll. */
  function heroDismissProgress(scrollY: number): number {
    const linear = Math.min(1, Math.max(0, scrollY / HERO_DISMISS_PX));
    return linear * linear * linear;
  }

  function measureHeroIntro() {
    if (!heroIntro) return;
    heroIntro.style.maxHeight = 'none';
    heroIntro.style.opacity = '1';
    heroIntro.style.transform = 'none';
    heroIntro.style.marginBottom = '';
    heroIntro.style.visibility = 'visible';
    heroIntroFullHeight = heroIntro.scrollHeight;
  }

  function resetHeroIntroStyles() {
    if (!heroIntro) return;
    heroIntro.style.opacity = '';
    heroIntro.style.transform = '';
    heroIntro.style.maxHeight = '';
    heroIntro.style.marginBottom = '';
    heroIntro.style.visibility = '';
    heroIntro.style.pointerEvents = '';
  }

  function setHeroScrollFade(scrollY: number) {
    const t = heroDismissProgress(scrollY);
    if (!heroIntro || heroIntroFullHeight === 0) return;

    heroIntro.style.opacity = String(1 - t);
    heroIntro.style.transform = `translateY(${-t * 12}px)`;
    heroIntro.style.maxHeight = `${heroIntroFullHeight * (1 - t)}px`;
    heroIntro.style.marginBottom = `${20 * (1 - t)}px`;
    heroIntro.style.pointerEvents = t >= 1 ? 'none' : '';
    heroIntro.style.visibility = t >= 0.98 ? 'hidden' : 'visible';

    const collapsed = scrollY >= 28;
    if (collapsed !== heroCollapsed) {
      heroCollapsed = collapsed;
      updateBrowsingUI();
    }
  }

  function updateBrowsingUI() {
    const query = searchEl?.value.trim() ?? '';
    const { category, protein, time } = activeFilters;
    const isBrowsing = Boolean(query || category || protein || time);

    featuredEl?.classList.toggle('hidden', isBrowsing || heroCollapsed);

    if (heroEl) {
      heroEl.classList.toggle('py-3', heroCollapsed);
      heroEl.classList.toggle('py-6', !heroCollapsed);
      heroEl.classList.toggle('mb-3', heroCollapsed);
      heroEl.classList.toggle('mb-6', !heroCollapsed);
      heroEl.classList.toggle('shadow-sm', heroCollapsed);
    }
  }

  function applyFilters() {
    const query = searchEl?.value.toLowerCase().trim() ?? '';
    const { category, protein, time } = activeFilters;
    const hasActive = query || category || protein || time;
    let visible = 0;

    rows.forEach(row => {
      const titleMatch = !query || (row.dataset.title ?? '').includes(query);
      const catMatch   = matchesMulti(row.dataset.category ?? '', category);
      const protMatch  = matchesMulti(row.dataset.protein  ?? '', protein);
      const mins       = parseInt(row.dataset.cookTime ?? '0', 10);
      let timeMatch    = true;
      if      (time === 'under30') timeMatch = mins > 0 && mins <= 30;
      else if (time === '30to60')  timeMatch = mins > 30 && mins <= 60;
      else if (time === 'over60')  timeMatch = mins > 60;

      const show = titleMatch && catMatch && protMatch && timeMatch;
      row.hidden = !show;
      if (show) visible++;
    });

    countEl.textContent = `(${visible})`;
    noRes.classList.toggle('hidden', visible > 0 || rows.length === 0);
    clearBtn.classList.toggle('hidden', !hasActive);
    updateActiveChips();
    updateBrowsingUI();
  }

  function clearFilterSelects() {
    if (categoryEl) categoryEl.value = '';
    if (proteinEl)  proteinEl.value  = '';
    if (timeEl)     timeEl.value     = '';
    activeFilters.category = '';
    activeFilters.protein  = '';
    activeFilters.time     = '';
    applyFilters();
  }

  function openFilterPanel() {
    filterPanel?.classList.remove('hidden');
    filterToggle?.setAttribute('aria-expanded', 'true');
    document.body.classList.add('overflow-hidden');
    updateActiveChips();
  }

  function closeFilterPanel() {
    filterPanel?.classList.add('hidden');
    filterToggle?.setAttribute('aria-expanded', 'false');
    document.body.classList.remove('overflow-hidden');
  }

  categoryEl?.addEventListener('change', syncFiltersFromSelects);
  proteinEl?.addEventListener('change', syncFiltersFromSelects);
  timeEl?.addEventListener('change', syncFiltersFromSelects);

  filterToggle?.addEventListener('click', openFilterPanel);
  filterPanelClear?.addEventListener('click', clearFilterSelects);
  document.getElementById('filter-panel-close')?.addEventListener('click', closeFilterPanel);
  document.getElementById('filter-panel-backdrop')?.addEventListener('click', closeFilterPanel);

  searchEl?.addEventListener('input', applyFilters);

  clearBtn?.addEventListener('click', () => {
    if (searchEl) searchEl.value = '';
    clearFilterSelects();
  });

  // Fade welcome copy on mobile scroll; search + filter stay pinned
  const mobileMq = window.matchMedia('(max-width: 639px)');
  function onScroll() {
    if (!mobileMq.matches) {
      resetHeroIntroStyles();
      if (heroCollapsed) {
        heroCollapsed = false;
        updateBrowsingUI();
      }
      return;
    }
    setHeroScrollFade(window.scrollY);
  }
  window.addEventListener('scroll', onScroll, { passive: true });
  mobileMq.addEventListener('change', () => {
    measureHeroIntro();
    onScroll();
  });
  window.addEventListener('resize', measureHeroIntro);
  measureHeroIntro();
  onScroll();

  applyFilters();
</script>

