---
import Layout from '../layouts/Layout.astro';
import RecipeCard from '../components/RecipeCard.astro';
import { supabase } from '../lib/supabase';
import { toDisplayLabel, splitValues } from '../lib/format';

const [{ data: recipes }, { data: featuredRaw }] = await Promise.all([
  supabase
    .from('recipes')
    .select('slug, title, category, protein, cook_time_min')
    .order('title'),
  supabase
    .from('recipes')
    .select('slug, title, category, protein, cook_time_min')
    .order('created_at', { ascending: false })
    .limit(4),
]);

const list     = recipes     ?? [];
const featured = featuredRaw ?? [];

// Build unique chip values by splitting multi-value fields
const categoryValues = [...new Set(
  list.flatMap(r => splitValues(r.category))
)].sort();

const proteinValues = [...new Set(
  list.flatMap(r => splitValues(r.protein))
)].sort();
---

<Layout title="Yumlog" activeNav="recipes">

  <!-- Hero -->
  <section class="bg-primary-container rounded-2xl px-5 py-6 mb-6 flex items-center justify-between gap-4">
    <div>
      <p class="text-xs font-medium text-primary uppercase tracking-widest mb-1">Tim &amp; Zoe's kitchen</p>
      <h1 class="font-serif text-2xl font-bold text-on-primary-container leading-snug">
        Everything we cook,<br />all in one place.
      </h1>
    </div>
    <svg class="shrink-0 text-primary opacity-60" width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M3 11l19-9-9 19-2-8-8-2z"/>
    </svg>
  </section>

  <!-- Search -->
  <div class="relative mb-4">
    <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 text-outline" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
    </svg>
    <input
      id="search"
      type="search"
      placeholder="Search recipes…"
      autocomplete="off"
      class="w-full bg-white border border-outline-soft rounded-2xl pl-10 pr-4 py-3 text-sm text-on-surface placeholder:text-outline focus:outline-none focus:ring-2 focus:ring-primary/40 focus:border-primary transition-colors"
    />
  </div>

  <!-- Filter chips -->
  <div class="space-y-2 mb-5">
    <!-- Category chips -->
    <div class="flex gap-2 overflow-x-auto pb-1 -mx-4 px-4 scrollbar-none" role="group" aria-label="Filter by category">
      <button
        data-group="category" data-chip-value=""
        class="chip-btn shrink-0 bg-primary text-on-primary rounded-full px-3 py-1.5 text-xs font-medium transition-colors"
      >
        All categories
      </button>
      {categoryValues.map(v => (
        <button
          data-group="category" data-chip-value={v}
          class="chip-btn shrink-0 bg-white border border-outline-soft text-on-surface-muted rounded-full px-3 py-1.5 text-xs font-medium transition-colors hover:bg-surface-container"
        >
          {toDisplayLabel(v)}
        </button>
      ))}
    </div>

    <!-- Protein chips -->
    <div class="flex gap-2 overflow-x-auto pb-1 -mx-4 px-4 scrollbar-none" role="group" aria-label="Filter by protein">
      <button
        data-group="protein" data-chip-value=""
        class="chip-btn shrink-0 bg-secondary text-on-secondary rounded-full px-3 py-1.5 text-xs font-medium transition-colors"
      >
        All proteins
      </button>
      {proteinValues.map(v => (
        <button
          data-group="protein" data-chip-value={v}
          class="chip-btn shrink-0 bg-white border border-outline-soft text-on-surface-muted rounded-full px-3 py-1.5 text-xs font-medium transition-colors hover:bg-surface-container"
        >
          {toDisplayLabel(v)}
        </button>
      ))}
    </div>

    <!-- Cook time chips -->
    <div class="flex gap-2 overflow-x-auto pb-1 -mx-4 px-4 scrollbar-none" role="group" aria-label="Filter by cook time">
      {([
        ['', 'Any time'],
        ['under30', '< 30 min'],
        ['30to60',  '30–60 min'],
        ['over60',  '> 60 min'],
      ] as const).map(([val, label]) => (
        <button
          data-group="time" data-chip-value={val}
          class={`chip-btn shrink-0 rounded-full px-3 py-1.5 text-xs font-medium transition-colors ${val === '' ? 'bg-surface-high text-on-surface border border-outline-soft' : 'bg-white border border-outline-soft text-on-surface-muted hover:bg-surface-container'}`}
        >
          {label}
        </button>
      ))}
    </div>
  </div>

  <!-- Featured -->
  {featured.length > 0 && (
    <section class="mb-8">
      <h2 class="font-serif text-lg font-bold text-on-surface mb-3">Recently added</h2>
      <div class="flex gap-3 overflow-x-auto pb-2 -mx-4 px-4 scrollbar-none snap-x snap-mandatory">
        {featured.map(r => (
          <div class="snap-start">
            <RecipeCard
              slug={r.slug}
              title={r.title}
              category={r.category}
              protein={r.protein}
              cook_time_min={r.cook_time_min}
            />
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- All recipes -->
  <section>
    <div class="flex items-baseline justify-between mb-3">
      <h2 class="font-serif text-lg font-bold text-on-surface">
        All recipes <span id="recipe-count" class="text-base font-sans font-normal text-on-surface-muted">({list.length})</span>
      </h2>
      <button id="clear-filters" class="hidden text-xs font-medium text-primary hover:underline">
        Clear filters
      </button>
    </div>

    {list.length === 0 && (
      <p class="text-on-surface-muted text-center py-20">No recipes yet — check back soon.</p>
    )}

    <ul id="recipe-list" class="flex flex-col divide-y divide-outline-soft">
      {list.map(r => (
        <li
          data-title={r.title.toLowerCase()}
          data-category={r.category ?? ''}
          data-protein={r.protein ?? ''}
          data-cook-time={r.cook_time_min ?? ''}
        >
          <a
            href={`/recipes/${r.slug}`}
            class="flex items-center justify-between gap-3 py-3.5 hover:bg-surface-low active:bg-surface-container transition-colors -mx-1 px-1 rounded-lg"
          >
            <span class="font-medium text-on-surface">{r.title}</span>
            <span class="flex items-center gap-2 shrink-0">
              {splitValues(r.category).slice(0, 1).map(c => (
                <span class="bg-primary-container text-on-primary-container text-xs rounded-full px-2 py-0.5 font-medium">
                  {toDisplayLabel(c)}
                </span>
              ))}
              {r.cook_time_min && (
                <span class="text-xs text-on-surface-muted whitespace-nowrap">{r.cook_time_min}&thinsp;min</span>
              )}
            </span>
          </a>
        </li>
      ))}
    </ul>

    <p id="no-results" class="hidden text-on-surface-muted text-center py-20">
      No recipes match these filters.
    </p>
  </section>

</Layout>

<script>
  // ── State ────────────────────────────────────────────────────────────────────
  const activeFilters: Record<string, string> = {
    category: '',
    protein:  '',
    time:     '',
  };

  // ── Elements ─────────────────────────────────────────────────────────────────
  const searchEl   = document.getElementById('search')        as HTMLInputElement;
  const listEl     = document.getElementById('recipe-list')!;
  const countEl    = document.getElementById('recipe-count')!;
  const noRes      = document.getElementById('no-results')!;
  const clearBtn   = document.getElementById('clear-filters')!;
  const rows       = listEl ? Array.from(listEl.querySelectorAll<HTMLLIElement>('li')) : [];

  // ── Helpers ──────────────────────────────────────────────────────────────────
  function matchesMulti(stored: string, filterValue: string): boolean {
    if (!filterValue) return true;
    return stored.split(',').map(v => v.trim()).includes(filterValue);
  }

  function applyFilters() {
    const query = searchEl?.value.toLowerCase().trim() ?? '';
    const { category, protein, time } = activeFilters;
    const hasActive = query || category || protein || time;
    let visible = 0;

    rows.forEach(row => {
      const titleMatch = !query || (row.dataset.title ?? '').includes(query);
      const catMatch   = matchesMulti(row.dataset.category ?? '', category);
      const protMatch  = matchesMulti(row.dataset.protein  ?? '', protein);
      const mins       = parseInt(row.dataset.cookTime ?? '0', 10);
      let timeMatch    = true;
      if      (time === 'under30') timeMatch = mins > 0 && mins <= 30;
      else if (time === '30to60')  timeMatch = mins > 30 && mins <= 60;
      else if (time === 'over60')  timeMatch = mins > 60;

      const show = titleMatch && catMatch && protMatch && timeMatch;
      row.hidden = !show;
      if (show) visible++;
    });

    countEl.textContent = `(${visible})`;
    noRes.classList.toggle('hidden', visible > 0 || rows.length === 0);
    clearBtn.classList.toggle('hidden', !hasActive);
  }

  // ── Chip clicks ──────────────────────────────────────────────────────────────
  const GROUP_ACTIVE: Record<string, { bg: string; text: string }> = {
    category: { bg: 'bg-primary',      text: 'text-on-primary' },
    protein:  { bg: 'bg-secondary',    text: 'text-on-secondary' },
    time:     { bg: 'bg-surface-high', text: 'text-on-surface' },
  };
  const INACTIVE_CLASSES = [
    'bg-white', 'border', 'border-outline-soft', 'text-on-surface-muted', 'hover:bg-surface-container',
  ];

  document.querySelectorAll<HTMLButtonElement>('.chip-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const group = btn.dataset.group!;
      const value = btn.dataset.chipValue!;

      // Deactivate all chips in this group
      document.querySelectorAll<HTMLButtonElement>(`.chip-btn[data-group="${group}"]`).forEach(b => {
        const { bg, text } = GROUP_ACTIVE[group];
        b.classList.remove(bg, text, 'border-none');
        b.classList.add(...INACTIVE_CLASSES);
      });

      // Activate the clicked chip
      const { bg, text } = GROUP_ACTIVE[group];
      btn.classList.remove(...INACTIVE_CLASSES);
      btn.classList.add(bg, text);

      activeFilters[group] = value;
      applyFilters();
    });
  });

  // ── Search ───────────────────────────────────────────────────────────────────
  searchEl?.addEventListener('input', applyFilters);

  // ── Clear all ────────────────────────────────────────────────────────────────
  clearBtn?.addEventListener('click', () => {
    if (searchEl) searchEl.value = '';
    Object.keys(activeFilters).forEach(k => { activeFilters[k] = ''; });

    // Reset all chips to inactive, then re-activate the "All" chips
    document.querySelectorAll<HTMLButtonElement>('.chip-btn').forEach(btn => {
      btn.classList.remove(
        'bg-primary', 'text-on-primary',
        'bg-secondary', 'text-on-secondary',
        'bg-surface-high', 'text-on-surface', 'border-none',
      );
      btn.classList.add(...INACTIVE_CLASSES);
    });
    document.querySelectorAll<HTMLButtonElement>('.chip-btn[data-chip-value=""]').forEach(btn => {
      const group = btn.dataset.group!;
      const { bg, text } = GROUP_ACTIVE[group];
      btn.classList.remove(...INACTIVE_CLASSES);
      btn.classList.add(bg, text);
    });

    applyFilters();
  });
</script>

<style>
  .scrollbar-none { scrollbar-width: none; }
  .scrollbar-none::-webkit-scrollbar { display: none; }
</style>
