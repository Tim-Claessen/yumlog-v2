---
import { toDisplayLabel, splitValues } from '../lib/format';

interface Props {
  slug: string;
  title: string;
  category?: string | null;
  protein?: string | null;
  cook_time_min?: number | null;
}

const { slug, title, category, protein, cook_time_min } = Astro.props;

const firstCategory = splitValues(category)[0] ?? null;

const GRADIENT_MAP: Record<string, string> = {
  curry:           'from-orange-400 to-amber-400',
  sourdough:       'from-amber-400 to-yellow-300',
  sweet_treat:     'from-rose-400 to-pink-300',
  salad:           'from-emerald-400 to-teal-400',
  soup:            'from-amber-500 to-orange-400',
  condiment:       'from-lime-400 to-green-400',
  meat:            'from-red-400 to-rose-400',
  noodles:         'from-yellow-400 to-amber-300',
  pasta:           'from-yellow-300 to-amber-300',
  pie:             'from-amber-600 to-orange-500',
  grains_rice:     'from-yellow-300 to-lime-300',
  seafood:         'from-cyan-400 to-teal-400',
  drink:           'from-blue-400 to-cyan-400',
  appetisers_sides:'from-orange-300 to-yellow-300',
  savoury:         'from-stone-400 to-amber-400',
};
const gradient = GRADIENT_MAP[firstCategory ?? ''] ?? 'from-[#B85C38] to-amber-400';
---

<a
  href={`/recipes/${slug}`}
  class="group flex flex-col bg-white rounded-2xl overflow-hidden shadow-sm border border-outline-soft hover:shadow-md hover:border-primary/30 transition-all duration-200 shrink-0 w-44"
  aria-label={title}
>
  <!-- Colour header -->
  <div class={`h-32 bg-gradient-to-br ${gradient}`}></div>

  <!-- Content -->
  <div class="p-3 flex flex-col gap-2 flex-1">
    <p class="font-medium text-sm text-on-surface leading-snug line-clamp-2">
      {title}
    </p>

    <div class="flex flex-wrap gap-1 mt-auto">
      {firstCategory && (
        <span class="bg-primary-container text-on-primary-container text-xs rounded-full px-2 py-0.5 font-medium">
          {toDisplayLabel(firstCategory)}
        </span>
      )}
      {cook_time_min && (
        <span class="bg-surface-container text-on-surface-muted text-xs rounded-full px-2 py-0.5">
          {cook_time_min}&thinsp;min
        </span>
      )}
    </div>
  </div>
</a>
